prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
includedir=${prefix}/${CMAKE_INSTALL_INCLUDEDIR}
libdir=${prefix}/${CMAKE_INSTALL_LIBDIR}

Name: ${_module_name}
Description: ${_description}
Version: ${_version}
Cflags: -I${includedir} -std=c++@SLIM_CXX_STANDARD@
Libs: -L${libdir} -l${_library_name} -Wl,-rpath,${libdir}